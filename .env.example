# Environment Variables untuk Nusa Media

# NewsAPI Configuration
# Dapatkan API key gratis dari https://newsapi.org/

# ⚠️ PENTING: Ganti dengan API key Anda sendiri
EXPO_PUBLIC_NEWS_API_KEY=YOUR_API_KEY_HERE

# App Configuration
EXPO_PUBLIC_APP_NAME=Nusa Media
EXPO_PUBLIC_APP_VERSION=1.0.0

# Catatan:
# 1. Buat file .env di root project
# 2. Copy isi file ini ke .env
# 3. Ganti YOUR_API_KEY_HERE dengan API key Anda
# 4. Jangan push .env ke GitHub (add ke .gitignore)
# 5. Restart app setelah perubahan: npm start
